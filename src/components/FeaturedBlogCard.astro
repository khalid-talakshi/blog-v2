---
// FeaturedBlogCard component - Display a featured blog post
// Entire card is clickable

export interface Props {
  title: string;
  description: string;
  date: string;
  href: string;
  image?: string;
  readingTime?: string;
}

const {
  title,
  description,
  date,
  href,
  image,
  readingTime = "5 min read",
} = Astro.props;

// Format date
const formatDate = (dateStr: string): string => {
  try {
    const [day, month, year] = dateStr.split("-");
    const dateObj = new Date(`${year}-${month}-${day}`);
    return dateObj.toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
};
---

<a
  href={href}
  class="card-glow group relative overflow-hidden rounded-2xl border border-theme-accent/30 bg-theme-accent/5 backdrop-blur-sm transition-all duration-300 hover:border-theme-accent/50 hover:shadow-lg hover:shadow-theme-accent/20 block h-full"
>
  {/* Cursor-following glow */}
  <div class="card-glow-effect pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100" aria-hidden="true"></div>
  
  <article class="h-full flex flex-col relative z-10">
    {/* Image */}
    {
      image && (
        <div class="relative h-48 overflow-hidden bg-theme-primary/10">
          <img
            src={image}
            alt={title}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
        </div>
      )
    }

    {/* Content */}
    <div class="p-6 md:p-8 flex flex-col flex-grow">
      {/* Meta */}
      <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-theme-text/60">
        <time datetime={date}>{formatDate(date)}</time>
        <span class="text-theme-accent">{readingTime}</span>
      </div>

      {/* Title */}
      <h3 class="mb-3 text-2xl md:text-3xl font-bold text-theme-foreground group-hover:text-theme-accent transition-colors duration-200">
        {title}
      </h3>

      {/* Description */}
      <p class="text-base text-theme-text/80 leading-relaxed line-clamp-3 flex-grow">
        {description}
      </p>
    </div>
  </article>
</a>
