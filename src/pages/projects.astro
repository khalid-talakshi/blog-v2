---
import StandardPageLayout from "../layouts/StandardPageLayout.astro";
import { getCollection } from "astro:content";

// Get all projects
const projects = await getCollection("projects");

// Get unique tags
const allTags = Array.from(
  new Set(projects.flatMap((p) => p.data.tags || []))
).sort();
---

<StandardPageLayout>
  {/* Page Header */}
  <section class="py-8 md:py-12 border-b border-theme-border/20">
    <h1 class="text-4xl md:text-5xl font-bold text-theme-foreground mb-4">
      Projects
    </h1>
    <p class="text-lg text-theme-text/80 max-w-2xl">
      A collection of projects I've built, designed, and shipped. Each one
      represents a unique challenge and learning opportunity.
    </p>
  </section>

  {/* Filter Section */}
  <section class="py-8 md:py-12 border-b border-theme-border/20">
    <div class="flex flex-wrap gap-2">
      <button
        class="filter-btn px-4 py-2 rounded-full font-medium transition-all duration-200 bg-gradient-to-r from-theme-accent to-theme-accent text-white shadow-lg shadow-theme-accent/30"
        data-filter="all"
      >
        All Projects
      </button>
      {
        allTags.map((tag) => (
          <button
            class="filter-btn px-4 py-2 rounded-full font-medium transition-all duration-200 border-2 border-theme-accent text-theme-accent hover:bg-theme-accent/10"
            data-filter={tag}
          >
            {tag}
          </button>
        ))
      }
    </div>
  </section>

  {/* Projects Grid */}
  <section class="py-12 md:py-16">
    {projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          projects.map((project) => (
            <article
              class="project-card group relative overflow-hidden rounded-2xl border border-theme-border/30 bg-gradient-to-br from-theme-accent/5 to-theme-secondary/5 backdrop-blur-sm transition-all duration-300 hover:border-theme-accent/50 hover:shadow-lg hover:shadow-theme-accent/20"
              data-tags={project.data.tags?.join(",")}
            >
              {/* Image */}
              {project.data.image && (
                <div class="relative h-40 overflow-hidden bg-theme-accent/10">
                  <img
                    src={project.data.image}
                    alt={project.data.title}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
                </div>
              )}

              {/* Content */}
              <div class="p-6">
                {/* Title */}
                <h3 class="mb-2 text-xl font-bold text-theme-accent group-hover:text-theme-primary transition-colors duration-200">
                  {project.data.title}
                </h3>

                {/* Description */}
                <p class="mb-4 text-sm text-theme-text/80 line-clamp-2">
                  {project.data.description}
                </p>

                {/* Technologies */}
                {project.data.technologies && project.data.technologies.length > 0 && (
                  <div class="mb-4 flex flex-wrap gap-1">
                    {project.data.technologies.slice(0, 2).map((tech: string) => (
                      <span class="inline-block px-2 py-1 rounded-full bg-theme-primary/20 text-xs font-medium text-theme-primary">
                        {tech}
                      </span>
                    ))}
                    {project.data.technologies.length > 2 && (
                      <span class="inline-block px-2 py-1 rounded-full bg-theme-primary/10 text-xs font-medium text-theme-text/60">
                        +{project.data.technologies.length - 2}
                      </span>
                    )}
                  </div>
                )}

                {/* Tags */}
                {project.data.tags && project.data.tags.length > 0 && (
                  <div class="mb-4 flex flex-wrap gap-1">
                    {project.data.tags.map((tag: string) => (
                      <span class="inline-block px-2 py-1 rounded-lg bg-theme-accent/20 text-xs font-medium text-theme-accent">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}

                {/* CTA */}
                <a
                  href={`/projects/${project.slug}`}
                  class="inline-flex items-center gap-2 text-theme-accent font-semibold hover:gap-3 transition-all duration-200"
                >
                  View Project
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-lg text-theme-text/60">
          No projects yet. Check back soon!
        </p>
      </div>
    )}
  </section>

  {/* CTA Section */}
  <section class="py-12 md:py-16 border-t border-theme-border/20">
    <div class="rounded-2xl border border-theme-border/30 bg-gradient-to-r from-theme-primary/10 to-theme-accent/10 p-8 md:p-12 text-center">
      <h2 class="text-3xl font-bold text-theme-primary mb-4">
        Have a Project in Mind?
      </h2>
      <p class="text-lg text-theme-text/80 mb-8 max-w-2xl mx-auto">
        I'm always interested in working on exciting projects. Let's collaborate
        and build something amazing together!
      </p>
      <a
        href="/about"
        class="inline-flex items-center gap-2 px-8 py-3 rounded-xl font-semibold text-white bg-gradient-to-r from-theme-primary to-theme-accent hover:shadow-lg hover:shadow-theme-primary/30 transition-all duration-300 hover:scale-105"
      >
        Get In Touch
        <svg
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          />
        </svg>
      </a>
    </div>
  </section>
</StandardPageLayout>

<script>
  // Filter functionality
  const filterBtns = document.querySelectorAll(".filter-btn");
  const projectCards = document.querySelectorAll(".project-card");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.getAttribute("data-filter");

      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove(
          "bg-gradient-to-r",
          "from-theme-primary",
          "to-theme-accent",
          "text-white",
          "shadow-lg",
          "shadow-theme-primary/30"
        );
        b.classList.add(
          "border-2",
          "border-theme-accent",
          "text-theme-accent",
          "hover:bg-theme-accent/10"
        );
      });
      btn.classList.remove(
        "border-2",
        "border-theme-accent",
        "text-theme-accent",
        "hover:bg-theme-accent/10"
      );
      btn.classList.add(
        "bg-gradient-to-r",
        "from-theme-primary",
        "to-theme-accent",
        "text-white",
        "shadow-lg",
        "shadow-theme-primary/30"
      );

      // Filter projects
      projectCards.forEach((card) => {
        if (filter === "all") {
          card.style.display = "block";
        } else {
          const tags = card.getAttribute("data-tags")?.split(",") || [];
          if (tags.includes(filter)) {
            card.style.display = "block";
          } else {
            card.style.display = "none";
          }
        }
      });
    });
  });
</script>
