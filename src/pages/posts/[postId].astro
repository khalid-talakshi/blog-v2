---
import { getCollection, getEntry, render } from "astro:content";
import Prose from "../../components/Prose.astro";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";

export async function getStaticPaths() {
  const blogPosts = await getCollection("blog");
  return blogPosts.map((post) => {
    return {
      params: {
        postId: post.id,
      },
    };
  });
}

const { postId } = Astro.params;

const entry = await getEntry("blog", postId);
const { Content } = await render(entry);
---

<BlogPostLayout>
  <div class="flex flex-col gap-4 mb-8 border-b border-theme-border/30 pb-8">
    <h1 class="text-5xl md:text-6xl font-bold text-theme-foreground">{entry.data.title}</h1>
    <h2 class="text-xl md:text-2xl text-theme-text/80">{entry?.data.description}</h2>
    <div class="flex flex-col md:flex-row md:justify-between gap-2 text-sm text-theme-text/60">
      <p>{entry?.data.author}</p>
      <p>{entry?.data.date}</p>
    </div>
  </div>
  <Prose>
    <Content />
  </Prose>
</BlogPostLayout>
